# Application
APP_NAME=DocMind
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://docmind:docmind_dev@localhost:5432/docmind

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider — Groq (FREE, get key at https://console.groq.com/keys)
LLM_API_KEY=gsk_your-groq-api-key-here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_FAST_MODEL=llama-3.1-8b-instant

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=docmind-documents

# Upload
MAX_UPLOAD_SIZE_MB=50

# CORS
CORS_ORIGINS=["http://localhost:3000"]
